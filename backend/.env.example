# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret        # from Supabase → Settings → API → JWT Secret

# OpenAI / OpenRouter
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Web Push (VAPID) — generate with: python -m pywebpush --gen-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@yourdomain.com

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app


# Sentry
SENTRY_DSN=

# Post-MVP: Razorpay (do not add in MVP)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
